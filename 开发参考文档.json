{
  "defaultLocale": "zh_CN",
  "supportedLocales": ["zh-CN", "en", "ru", "ja", "ko", "fr", "de", "es"],
  "mail": "main@autogo.top",
  "pageStyle": {
    "theme": "dark",
    "colors": {
      "primary": "#4a9eff",
      "primaryHover": "#3a8eef",
      "background": "#1e1e1e",
      "cardBackground": "#252526",
      "cardHover": "#2a2d2e",
      "text": "#d4d4d4",
      "textSecondary": "#808080",
      "border": "#454545",
      "scrollbarBackground": "#1e1e1e",
      "scrollbarThumb": "#424242"
    },
    "fontFamily": "'Segoe UI', 'Microsoft YaHei', sans-serif",
    "borderRadius": "12px",
    "cardMinWidth": "280px"
  },
  "modules": {
    "index": {
      "name": "导航主页",
      "path": "./index.html",
      "description": "工具集导航页面，提供多语言支持和工具卡片展示",
      "features": [
        "多语言切换（8 种语言）",
        "工具卡片网格布局",
        "语言偏好本地存储",
        "响应式设计",
        "深色主题"
      ],
      "components": [
        "header - 标题和语言选择器",
        "welcome-section - 欢迎区域",
        "tools-grid - 工具卡片网格",
        "footer - 页脚和邮箱链接"
      ]
    },
    "log_viewer": {
      "name": "Log 文件浏览器",
      "path": "./log_viewer/index.html",
      "description": "快速、强大的日志文件查看工具",
      "features": [
        "多编码支持（UTF-8, GBK, Big5 等）",
        "语法高亮",
        "正则表达式过滤",
        "行号显示",
        "文件拖拽上传",
        "关键词搜索",
        "自动滚动",
        "深色主题"
      ]
    },
    "regex_generator": {
      "name": "正则表达式生成器",
      "path": "./regex_generator/index.html",
      "description": "通过示例字符串自动生成正则表达式",
      "features": [
        "示例字符串输入",
        "自动正则匹配",
        "多语言支持",
        "正则表达式测试",
        "结果导出"
      ]
    }
  }
  
  
}
